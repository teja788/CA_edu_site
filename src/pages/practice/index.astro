---
import Base from '../../layouts/Base.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Badge from '../../components/Badge.astro';
import { attempt, questions } from '../../data/site.js';

// Real deck size for the P1 set: legacy launch questions + every Inter P1
// bank MCQ (case-set sub-questions count individually, as in the quiz).
const bankModules = import.meta.glob('../../data/questions/**/*.json', { eager: true });
let interP1Mcqs = 0;
for (const mod of Object.values(bankModules)) {
  const bank = mod.default ?? mod;
  if (!Array.isArray(bank.questions) || bank.paperSlug !== 'advanced-accounting') continue;
  for (const q of bank.questions) {
    if (q.type === 'mcq') interP1Mcqs += 1;
    else if (q.type === 'case_mcq_set' && Array.isArray(q.questions)) interP1Mcqs += q.questions.length;
  }
}
const p1SetCount = questions.length + interP1Mcqs;
---

<Base title="Practice" active="practice">
  <main class="page">
    <Breadcrumb crumbs={[{ label: 'Home', href: '/' }, { label: 'Practice' }]} />

    <div class="overline" style="margin-bottom: 6px;">Retrieval practice · the highest-utility study technique</div>
    <h1 style="margin: 0 0 12px; font-size: 30px; font-weight: 700; letter-spacing: -0.01em; line-height: 1.25;">Practice</h1>
    <p style="max-width: 640px; font-size: 17px; line-height: 1.7; color: var(--text-2); margin: 0 0 24px;">
      Original questions, never copied from ICAI papers. Every option — right or wrong — explains itself.
      Wrong answers are saved to your Mistake notebook and resurfaced later.
    </p>

    <div class="list-card" style="max-width: 720px;">
      <a class="list-row" href="/practice/quiz/?level=intermediate&paper=advanced-accounting">
        <span style="flex: 1;">
          <span style="display: block; font-size: 16px; font-weight: 600;">Paper 1 · full practice set</span>
          <span style="font-size: 13px; color: var(--text-2);">{p1SetCount} questions · accounting standards + company accounts · per-option explanations</span>
        </span>
        <Badge kind="verified">{attempt.name}</Badge>
        <span class="chev" aria-hidden="true">›</span>
      </a>
      <a class="list-row" href="/practice/quiz/?topic=admission">
        <span style="flex: 1;">
          <span style="display: block; font-size: 16px; font-weight: 600;">Ch 4 · Partnership · Admission of a partner</span>
          <span style="font-size: 13px; color: var(--text-2);">{questions.filter((q) => q.topic.includes('Admission')).length} questions · topic drill</span>
        </span>
        <span class="chev" aria-hidden="true">›</span>
      </a>
      <a class="list-row" href="/practice/quiz/?mode=mixed&timed=1">
        <span style="flex: 1;">
          <span style="display: block; font-size: 16px; font-weight: 600;">Mixed timed drill</span>
          <span style="font-size: 13px; color: var(--text-2);">All topics shuffled, elapsed clock running — closest to the exam</span>
        </span>
        <span class="chev" aria-hidden="true">›</span>
      </a>
      <a class="list-row" href="/practice/descriptive/">
        <span style="flex: 1;">
          <span style="display: block; font-size: 16px; font-weight: 600;">Descriptive practice — write, then self-grade</span>
          <span style="font-size: 13px; color: var(--text-2);">Timed prompt → rubric reveal: points, citations, working notes, marks (Inter 70%)</span>
        </span>
        <span class="chev" aria-hidden="true">›</span>
      </a>
      <a class="list-row" href="/practice/mock/">
        <span style="flex: 1;">
          <span style="display: block; font-size: 16px; font-weight: 600;">Mock composer — 100-mark paper</span>
          <span style="font-size: 13px; color: var(--text-2);">Official 30:70 shape, filtered to your attempt, honest about bank shortfall</span>
        </span>
        <span class="chev" aria-hidden="true">›</span>
      </a>
      <a class="list-row" href="/practice/flashcards/">
        <span style="flex: 1;">
          <span style="display: block; font-size: 16px; font-weight: 600;">Flashcards — spaced review</span>
          <span style="font-size: 13px; color: var(--text-2);" data-due-count>AS numbers, formulas, rules — scheduled so you don't have to</span>
        </span>
        <span class="chev" aria-hidden="true">›</span>
      </a>
      <a class="list-row" href="/practice/quiz/?mode=mistakes">
        <span style="flex: 1;">
          <span style="display: block; font-size: 16px; font-weight: 600;">From your Mistake notebook</span>
          <span style="font-size: 13px; color: var(--text-2);" data-mistake-count>Questions you got wrong, back for another look</span>
        </span>
        <span class="chev" aria-hidden="true">›</span>
      </a>
    </div>

    <div class="empty-state" style="max-width: 720px; margin-top: 24px;">
      <div style="width: 40px; height: 40px; border-radius: 999px; background: var(--surface-2); color: var(--text-3); display: inline-flex; align-items: center; justify-content: center; font-size: 18px; margin-bottom: 10px;" aria-hidden="true">✎</div>
      <div style="font-size: 16px; font-weight: 650; margin-bottom: 4px;">More sets on the way</div>
      <div style="font-size: 14px; color: var(--text-2); line-height: 1.55; margin-bottom: 14px;">
        The question bank grows chapter by chapter — Advanced Accounting first, Taxation last
        (only once amendment-tagging is battle-tested).
      </div>
      <a href="/intermediate/advanced-accounting/" class="btn btn-secondary">Browse chapters</a>
    </div>
  </main>

  <script>
    import { getMistakes, getDueCards } from '../../scripts/store.js';
    import { allCards } from '../../data/flashcards.js';
    const n = getMistakes().length;
    const el = document.querySelector('[data-mistake-count]');
    if (el && n > 0) el.textContent = `${n} question${n === 1 ? '' : 's'} waiting for another look`;
    const due = getDueCards(allCards).length;
    const dueEl = document.querySelector('[data-due-count]');
    if (dueEl && due > 0) dueEl.textContent = `${due} card${due === 1 ? '' : 's'} due now — about ${Math.max(1, Math.round(due * 0.5))} minutes`;
  </script>
</Base>
