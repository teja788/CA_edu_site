---
import Base from '../layouts/Base.astro';
---

<Base title="Page not found" description="This page doesn't exist — but every free CA resource you need is one click away.">
  <main class="page">
    <section style="max-width: 640px; margin: 0 auto; padding: 48px 0; text-align: center;">
      <div class="overline">404 · Page not found</div>
      <h1 style="margin: 12px 0 0; font-size: 30px; font-weight: 700; letter-spacing: -0.01em; line-height: 1.25;">
        This page isn't in the syllabus.
      </h1>
      <p style="font-size: 17px; line-height: 1.7; color: var(--text-2); margin: 16px 0 28px;">
        The link may be old, or the page may have moved while we reorganise.
        Everything on Adhyayan is still free and still here — try one of these instead.
      </p>
      <div style="display: flex; gap: 16px; flex-wrap: wrap; align-items: center; justify-content: center;">
        <a href="/" class="btn btn-primary">Back to home</a>
        <a href="/practice/" class="btn btn-secondary">Try a practice set</a>
        <a href="/search/" class="btn btn-tertiary">Search topics</a>
      </div>
    </section>
  </main>
</Base>
