---
import Base from '../layouts/Base.astro';
import AdSlot from '../components/AdSlot.astro';
import { attempt, papers } from '../data/site.js';
---

<Base title="Dashboard" active="dashboard">
  <main class="page">
    <!-- greeting + factual attempt line -->
    <div style="display: flex; justify-content: space-between; align-items: flex-end; gap: 24px; margin-bottom: 24px; flex-wrap: wrap;">
      <div>
        <h1 style="margin: 0; font-size: 26px; font-weight: 700; line-height: 1.3;" data-greeting>Welcome</h1>
        <div style="font-size: 15px; color: var(--text-2); margin-top: 4px;">Picking up where you left off: Ch 4 · Partnership accounts</div>
      </div>
      <div class="tnum" style="text-align: right; font-size: 14px; color: var(--text-2);">
        <div>{attempt.name} attempt begins <strong style="color: var(--text);">{attempt.beginsLabel}</strong></div>
        <div style="color: var(--text-3);"><span data-days-left></span><a href="/intermediate/">change attempt</a></div>
      </div>
    </div>

    <div class="dash-grid">
      <!-- left column -->
      <div style="display: flex; flex-direction: column; gap: 24px; min-width: 0;">
        <!-- review queue — never interrupted by ads -->
        <section class="card card-pad">
          <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 4px; gap: 12px; flex-wrap: wrap;">
            <div style="font-size: 18px; font-weight: 700;">Today's review</div>
            <div style="font-size: 13px; color: var(--text-3);">Spaced repetition · <a href="/about/">how this works</a></div>
          </div>
          <div style="font-size: 14px; color: var(--text-2); margin-bottom: 16px;" data-queue-caption>
            Anything skipped simply waits.
          </div>
          <div style="display: flex; flex-direction: column;" data-queue>
            <div style="display: flex; align-items: center; gap: 14px; min-height: 52px; border-top: 1px solid var(--surface-2);">
              <span style="width: 22px; height: 22px; border-radius: 6px; background: var(--accent-tint); color: var(--accent); display: inline-flex; align-items: center; justify-content: center; font-size: 11px; flex-shrink: 0;" aria-hidden="true">✎</span>
              <span style="flex: 1; font-size: 15px; font-weight: 600;">Admission of a partner — practice set</span>
              <span style="font-size: 13px; color: var(--text-3);">P1 · Ch 4</span>
            </div>
            <div style="display: flex; align-items: center; gap: 14px; min-height: 52px; border-top: 1px solid var(--surface-2); border-bottom: 1px solid var(--surface-2);">
              <span style="width: 22px; height: 22px; border-radius: 6px; background: var(--incorrect-tint); color: var(--incorrect-text); display: inline-flex; align-items: center; justify-content: center; font-size: 11px; flex-shrink: 0;" aria-hidden="true">✕</span>
              <span style="flex: 1; font-size: 15px; font-weight: 600;" data-queue-mistakes>From Mistake notebook</span>
              <span style="font-size: 13px; color: var(--text-3);">Mixed</span>
            </div>
          </div>
          <a href="/practice/quiz/" class="btn btn-primary" style="margin-top: 18px;">Start today's review</a>
        </section>

        <!-- ad slot BELOW the queue card -->
        <AdSlot />

        <!-- recent mistakes -->
        <section class="card card-pad" id="mistakes">
          <div style="display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 14px;">
            <div style="font-size: 18px; font-weight: 700;">Recent mistakes</div>
            <a href="/practice/quiz/?mode=mistakes" style="font-size: 14px; font-weight: 600; text-decoration: none;">Retry all →</a>
          </div>
          <div style="display: flex; flex-direction: column;" data-mistake-list>
            <div class="empty-state" style="border: none; padding: 20px 0;">
              <div style="font-size: 14px; color: var(--text-2);">No mistakes logged yet. They'll appear here after you practise.</div>
            </div>
          </div>
        </section>
      </div>

      <!-- right rail -->
      <div style="display: flex; flex-direction: column; gap: 24px; min-width: 0;">
        <section class="card card-pad">
          <div style="font-size: 18px; font-weight: 700; margin-bottom: 16px;">Your papers</div>
          <div style="display: flex; flex-direction: column; gap: 18px;">
            {papers.filter((p) => p.group === 1).map((p) => (
              <div>
                <div style="display: flex; justify-content: space-between; font-size: 14px; margin-bottom: 6px;">
                  <span style={`font-weight: 600; ${p.status !== 'live' ? 'color: var(--text-3);' : ''}`}>P{p.number} · {p.shortName}</span>
                  {p.status === 'live'
                    ? <span class="tnum" style="color: var(--text-2);" data-paper-pct={p.id}>0%</span>
                    : <span style="font-size: 13px; color: var(--text-3);">Coming soon</span>}
                </div>
                <div class="progress-track">
                  {p.status === 'live' && <div class="progress-fill" style="width: 0%;" data-paper-fill={p.id}></div>}
                </div>
              </div>
            ))}
          </div>
          <a href="/intermediate/" style="display: inline-flex; align-items: center; min-height: 44px; font-size: 14px; font-weight: 600; text-decoration: none; margin-top: 10px;">All papers →</a>
        </section>

        <section class="card card-pad">
          <div style="font-size: 15px; font-weight: 700; margin-bottom: 8px;">This week</div>
          <div class="tnum" style="font-size: 14px; color: var(--text-2); line-height: 1.7;" data-week-stats>
            No sessions yet this week.
          </div>
          <div style="font-size: 13px; color: var(--text-3); margin-top: 10px; line-height: 1.55;">
            A quiet week is fine. The queue adjusts to you.
          </div>
        </section>
      </div>
    </div>
  </main>

  <style>
    .dash-grid {
      display: grid;
      grid-template-columns: 1.5fr 1fr;
      gap: 24px;
      align-items: start;
    }
    @media (max-width: 800px) {
      .dash-grid { grid-template-columns: 1fr; }
    }
  </style>

  <script>
    import { getMistakes, getWeekStats, getPaperProgress } from '../scripts/store.js';

    // Greeting by time of day — factual, no pressure.
    const h = new Date().getHours();
    document.querySelector('[data-greeting]').textContent =
      h < 12 ? 'Good morning' : h < 17 ? 'Good afternoon' : 'Good evening';

    // Factual countdown.
    const begins = new Date('2026-09-08T00:00:00+05:30');
    const days = Math.max(0, Math.ceil((begins.getTime() - Date.now()) / 86400000));
    document.querySelector('[data-days-left]').textContent = `${days} days from today · `;

    // Review queue caption + mistake row.
    const mistakes = getMistakes();
    document.querySelector('[data-queue-caption]').textContent = mistakes.length > 0
      ? `${mistakes.length + 1} items due. Anything skipped simply waits.`
      : 'One practice set due. Anything skipped simply waits.';
    document.querySelector('[data-queue-mistakes]').textContent = mistakes.length > 0
      ? `From Mistake notebook — ${mistakes.length} question${mistakes.length === 1 ? '' : 's'}`
      : 'Mistake notebook — empty, nothing waiting';

    // Recent mistakes list.
    if (mistakes.length > 0) {
      const wrap = document.querySelector('[data-mistake-list]');
      wrap.innerHTML = '';
      mistakes.slice(0, 5).forEach((m, i) => {
        const row = document.createElement('div');
        row.style.cssText = `display: flex; align-items: center; gap: 14px; min-height: 52px; border-top: 1px solid var(--surface-2); ${i === Math.min(mistakes.length, 5) - 1 ? 'border-bottom: 1px solid var(--surface-2);' : ''}`;
        row.innerHTML = `<span style="flex: 1; font-size: 15px;">${m.topic}</span>
          <a href="/practice/quiz/?mode=mistakes" style="font-size: 14px; font-weight: 600; text-decoration: none; min-height: 44px; display: flex; align-items: center;">Retry</a>`;
        wrap.appendChild(row);
      });
    }

    // This week facts.
    const stats = getWeekStats();
    if (stats.attempted > 0) {
      document.querySelector('[data-week-stats]').innerHTML =
        `${stats.attempted} questions attempted · ${stats.correct} correct`;
    }

    // Paper progress.
    const p1 = getPaperProgress('p1', 96);
    const pct = document.querySelector('[data-paper-pct="p1"]');
    const fill = document.querySelector('[data-paper-fill="p1"]');
    if (pct) pct.textContent = `${p1.pct}%`;
    if (fill) fill.style.width = `${p1.pct}%`;
  </script>
</Base>
