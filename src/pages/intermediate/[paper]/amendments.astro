---
import Base from '../../../layouts/Base.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import Badge from '../../../components/Badge.astro';
import TrustRow from '../../../components/TrustRow.astro';
import { attempt } from '../../../data/site.js';
import { intermediatePapers, attempts } from '../../../data/intermediate.js';
import { amendmentsForPaper } from '../../../data/amendments.js';

/**
 * Per-paper amendment tracker (plan §6.4 rule 4): sourced changelog —
 * notification/Finance Act ref → what changed → affected content.
 */
export function getStaticPaths() {
  return intermediatePapers.map((p) => ({ params: { paper: p.slug }, props: { paper: p } }));
}

const { paper } = Astro.props;
const entries = amendmentsForPaper(paper.slug);
---

<Base title={`Amendment tracker — Paper ${paper.number}: ${paper.name}`}>
  <main class="page">
    <Breadcrumb crumbs={[
      { label: 'CA Intermediate', href: '/intermediate/' },
      { label: `Paper ${paper.number} · ${paper.shortName}`, href: `/intermediate/${paper.slug}/` },
      { label: 'Amendments' },
    ]} />

    <div class="overline" style="margin-bottom: 6px;">What changed since the SM edition · “{paper.edition}”</div>
    <h1 style="margin: 0; font-size: 30px; font-weight: 700; letter-spacing: -0.01em; line-height: 1.25;">
      Amendments — Paper {paper.number}: {paper.name}
    </h1>
    <div style="margin: 12px 0 0;">
      <TrustRow attempt={attempt.name} updated="3 Jul 2026" source="Each entry cites its notification / announcement" />
    </div>

    {paper.volatile && (
      <div class="card card-pad" style="max-width: 720px; margin-top: 20px;">
        <div class="overline" style="margin-bottom: 10px;">Applicable law by attempt</div>
        <div style="overflow-x: auto;">
        <table style="width: 100%; min-width: 520px; border-collapse: collapse; font-size: 14px;">
          <thead>
            <tr style="color: var(--text-3); text-align: left;">
              <th style="font-weight: 600; padding: 4px 0;">Attempt</th>
              <th style="font-weight: 600; padding: 4px 0;">Income tax</th>
              <th style="font-weight: 600; padding: 4px 0;">Cut-off</th>
            </tr>
          </thead>
          <tbody style="line-height: 1.8; vertical-align: top;">
            {attempts.map((a) => (
              <tr>
                <td style="padding: 6px 12px 6px 0; white-space: nowrap;"><strong>{a.name}</strong>{!a.verified && <Badge kind="draft">verify</Badge>}</td>
                <td style="padding: 6px 12px 6px 0;">{a.incomeTaxLaw}</td>
                <td style="padding: 6px 0;" class="tnum">{a.amendmentCutoff.date}<span style="display: block; font-size: 12px; color: var(--text-3);">{a.amendmentCutoff.basis}</span></td>
              </tr>
            ))}
          </tbody>
        </table>
        </div>
      </div>
    )}

    <div style="display: flex; flex-direction: column; gap: 16px; margin-top: 28px; max-width: 720px;">
      {entries.map((a) => (
        <div class="card card-pad">
          <div style="display: flex; justify-content: space-between; gap: 12px; align-items: flex-start; flex-wrap: wrap; margin-bottom: 8px;">
            <div class="overline" style="font-size: 12px;">{a.paperLabel}</div>
            <span style="display: flex; gap: 6px; flex-wrap: wrap; justify-content: flex-end;">
              {a.todo && <Badge kind="draft">Pending transcription</Badge>}
              <Badge kind="amended">Applies from {a.appliesFrom}</Badge>
            </span>
          </div>
          <div style="font-size: 17px; font-weight: 650; margin-bottom: 10px;">{a.title}</div>
          <div style="font-size: 15px; line-height: 1.65;">
            <span style="text-decoration: line-through; color: var(--text-3);">{a.old}</span><br />
            {a.now}
          </div>
          <div class="trust-row" style="margin-top: 12px;">
            <span>Source: <a href={a.sourceUrl} rel="noopener">{a.source} ↗</a></span>
            {a.affected.map((n) => (
              <>
                <span class="dot" aria-hidden="true">·</span>
                <a href={n.href}>Affected: {n.label}</a>
              </>
            ))}
            {a.affected.length === 0 && (
              <>
                <span class="dot" aria-hidden="true">·</span>
                <span>No published content affected yet</span>
              </>
            )}
          </div>
        </div>
      ))}
    </div>

    {entries.length === 0 && (
      <div class="empty-state" style="max-width: 720px; margin-top: 24px;">
        <div style="font-size: 16px; font-weight: 650; margin-bottom: 4px;">No tracked amendments for this paper yet</div>
        <div style="font-size: 14px; color: var(--text-2); line-height: 1.55;">
          {paper.volatile
            ? 'This is a law/tax paper — entries will appear here as ICAI statutory updates are transcribed.'
            : 'This paper is standards-based and stable; changes are rare and will be tracked here when they happen.'}
        </div>
      </div>
    )}

    <div class="empty-state" style="max-width: 720px; margin-top: 24px;">
      <div style="font-size: 14px; color: var(--text-2); line-height: 1.55; margin-bottom: 14px;">
        The tracker follows the ecosystem's rhythm: Finance Act (Feb–Apr), GST notifications (rolling),
        SM edition updates, RTP releases (~2 months pre-exam). Spotted something missing?
      </div>
      <a href={`/report-error/?page=${encodeURIComponent(`/intermediate/${paper.slug}/amendments/`)}`} class="btn btn-secondary">Report a missing amendment</a>
    </div>
  </main>
</Base>
