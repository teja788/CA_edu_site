---
/** Mastery states: 0 Not started · 1 Familiar · 2 Proficient · 3 Mastered */
interface Props {
  level?: 0 | 1 | 2 | 3;
  showLabel?: boolean;
  topicId?: string;
}
const { level = 0, showLabel = true, topicId } = Astro.props;
const labels = ['Not started', 'Familiar', 'Proficient', 'Mastered ✓'];
---

<span class="mastery" data-mastery={topicId}>
  <span class="segs" aria-hidden="true">
    {[0, 1, 2].map((i) => (
      <span class={`seg ${i < level ? 'on' : ''}`}></span>
    ))}
  </span>
  {showLabel && <span class="label" data-mastery-label>{labels[level]}</span>}
</span>

<script>
  // Hydrate every mastery widget on the page from local progress. Astro
  // dedupes component scripts, so this runs once per page.
  import { getMastery } from '../scripts/store.js';
  const labels = ['Not started', 'Familiar', 'Proficient', 'Mastered ✓'];
  document.querySelectorAll('[data-mastery]').forEach((el) => {
    const level = getMastery(el.dataset.mastery);
    if (!level) return;
    el.querySelectorAll('.seg').forEach((seg, i) => seg.classList.toggle('on', i < level));
    const label = el.querySelector('[data-mastery-label]');
    if (label) label.textContent = labels[level];
  });
</script>
