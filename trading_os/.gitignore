# Secrets — never commit
.env
*.pem
kite_token*.json

# Data — local only, never commit. Anchored to this directory: an unanchored
# "data/" also matches src/tradingos/data/ and tests/data/ (the data-layer
# source), which silently kept the whole data layer out of git.
/data/
/artifacts/
*.duckdb
*.duckdb.wal
*.sqlite
*.sqlite3
*.db

# Python
__pycache__/
*.pyc
.venv/
*.egg-info/
dist/
build/
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/
uv.lock
