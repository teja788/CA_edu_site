# Copy to .env and fill in. NEVER commit .env (it is git-ignored).
# All variables use the TOS_ prefix.

# --- Kite Connect (https://developers.kite.trade/apps) ---
TOS_KITE_API_KEY=
TOS_KITE_API_SECRET=
TOS_KITE_USER_ID=
# Optional: enables the TOTP-assisted login flow
TOS_KITE_PASSWORD=
TOS_KITE_TOTP_SECRET=

# --- Telegram alerts (optional) ---
TOS_TELEGRAM_BOT_TOKEN=
TOS_TELEGRAM_CHAT_ID=

# --- Paths (defaults shown) ---
# TOS_DATA_DIR=data
# TOS_ARTIFACTS_DIR=artifacts

# --- Live risk limits (defaults shown) ---
# TOS_MAX_ORDER_VALUE=200000
# TOS_MAX_POSITION_PCT=0.10
# TOS_MAX_DAILY_LOSS=25000
# TOS_MAX_ORDERS_PER_DAY=50
